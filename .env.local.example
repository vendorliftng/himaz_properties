# Himaz Properties — Environment Variables

# Supabase (required for lead persistence)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin Dashboard Password
NEXT_PUBLIC_ADMIN_PASSWORD=your-secure-admin-password

# n8n Webhook (optional — for WhatsApp automation)
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/lead-capture
